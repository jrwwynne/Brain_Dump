# ============================================================
# Voice Brain Dump — environment variable configuration
# Copy this file to .env and fill in your own values.
# ============================================================

# ------------------------------------------------------------
# Ollama server
# ------------------------------------------------------------
# URL of the machine running Ollama on your local network.
OLLAMA_BASE_URL=http://192.168.1.199:11434

# Ollama model to use for task extraction.
OLLAMA_MODEL=gemma4

# How long (seconds) to wait for Ollama before timing out.
OLLAMA_TIMEOUT=60

# ------------------------------------------------------------
# Audio & whisper.cpp
# ------------------------------------------------------------
# ALSA device string for your USB microphone.
AUDIO_DEVICE=plughw:3,0

# Absolute path to the whisper-cli binary.
WHISPER_BINARY=/home/james/whisper.cpp/build/bin/whisper-cli

# Absolute path to the whisper model weights.
WHISPER_MODEL=/home/james/whisper.cpp/models/ggml-base.en.bin

# Temporary WAV file written during recording.
AUDIO_FILE=/tmp/brain_dump.wav

# ------------------------------------------------------------
# Flask
# ------------------------------------------------------------
# Host to bind the web server to (0.0.0.0 exposes it on the local network).
FLASK_HOST=0.0.0.0

# Port for the web UI.
FLASK_PORT=5000

# Set to true only during development — never in production.
FLASK_DEBUG=false
# testing runner